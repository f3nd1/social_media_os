# Optional Supabase env fallback for the workspace sync.
# The Settings > Supabase database panel stores credentials in localStorage and
# takes priority over these values. Set these so the dev container does not need
# the credentials re-entered after a restart.
#
# Use only the anon / publishable key here. Never put the service_role key in a
# NEXT_PUBLIC_ variable, as it is exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
